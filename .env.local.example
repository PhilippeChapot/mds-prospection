# MDS Prospection — Variables d'environnement
# Copier ce fichier en .env.local et remplir au fur et a mesure.
# Les blocs marques [P0] sont necessaires pour la Phase 0.
# Les blocs marques [P3+] arrivent au moment ou on cable l'integration.

# === [P0] Supabase ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# Mot de passe DB (utilise par `supabase db push` non interactif). Optionnel.
SUPABASE_DB_PASSWORD=

# === [P0] Anthropic (classification IA + assistant chat) ======================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# === [P0] Sentry ==============================================================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Pour upload des sourcemaps en CI :
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# === [P0] hCaptcha (anti-spam, widget pose en P3) =============================
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# === [P0] i18n + App ==========================================================
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NEXT_PUBLIC_SUPPORTED_LOCALES=fr,en
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === [P0] Canva (lien public plan implantation) ===============================
NEXT_PUBLIC_CANVA_PLAN_URL=https://canva.link/md26plan

# === [P4] Stripe (apres KYC) ==================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === [P4] Sellsy (deja chez Phil) =============================================
SELLSY_CLIENT_ID=
SELLSY_CLIENT_SECRET=
SELLSY_API_KEY=
SELLSY_WEBHOOK_SECRET=

# === [P4] Brevo (deja chez Phil - 150K envois/mois) ===========================
BREVO_API_KEY=
BREVO_LIST_ID_AWAITING=
BREVO_LIST_ID_VERIFIED=
BREVO_LIST_ID_PRS_ELIGIBLE=
BREVO_LIST_ID_SIGNED=
BREVO_LIST_ID_NON_ELIGIBLE=
BREVO_LIST_ID_POLE_REGIES_RETAIL_MEDIA=
BREVO_LIST_ID_POLE_AUDIO_RADIO=
BREVO_LIST_ID_POLE_DIFFUSION_INFRA=
BREVO_LIST_ID_POLE_VIDEO_CTV=
BREVO_LIST_ID_POLE_OUTDOOR_DOOH=
BREVO_LIST_ID_POLE_DATA_ADTECH=

# === [P4] NeverBounce (verification deliverability) ===========================
NEVERBOUNCE_API_KEY=
NEVERBOUNCE_SANDBOX=true

# === [P5] Connectonair (read-only par email) ==================================
CONNECTONAIR_API_BASE_URL=
CONNECTONAIR_API_KEY=
